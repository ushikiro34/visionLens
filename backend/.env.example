# ── App ────────────────────────────────────────────
APP_NAME=K-Food Vision Lens
APP_VERSION=1.0.0
DEBUG=false

# ── PostgreSQL ─────────────────────────────────────
# [Railway] Database 플러그인 추가 시 자동 주입됨:
#   DATABASE_URL=postgresql://user:pass@host:port/db
# [로컬 Docker] 개별 변수 사용:
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=kfood
POSTGRES_USER=kfood_user
POSTGRES_PASSWORD=your_secure_password_here

# ── Redis ──────────────────────────────────────────
# [Railway] Redis 플러그인 추가 시 자동 주입됨:
#   REDIS_URL=redis://default:pass@host:port
# [로컬 Docker] 개별 변수 사용:
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# ── 식약처 API (절대 클라이언트에 노출 금지) ──────────
# 공공데이터포털(data.go.kr) → 식품의약품안전처_식품영양성분DB정보 → 인증키
MFDS_API_KEY=your_mfds_api_key_here
# MFDS_BASE_URL=https://apis.data.go.kr/1471000/FoodNtrCpntDbInfo02
# MFDS_SERVICE_ID=getFoodNtrCpntDbInq02

# ── ChromaDB ───────────────────────────────────────
CHROMA_HOST=chromadb
CHROMA_PORT=8000
CHROMA_COLLECTION=kfood_nutrients

# ── HITL 임계값 ────────────────────────────────────
YOLO_CONFIDENCE_THRESHOLD=0.85
RAG_SIMILARITY_THRESHOLD=0.78

# ── YOLO 모델 경로 ──────────────────────────────────
YOLO_MODEL_PATH=models/kfood_yolov8s_seg.pt
